# Leeway Skills MCP Server Configuration
# Copy to .env and customize for your environment

# Application
NODE_ENV=development
DEBUG=leeway-skills:*

# Paths
LEEWAY_SKILLS_PATH=c:\Tools\Leeway-Skills
REGISTRY_PATH=c:\Tools\Leeway-Skills\scripts\skills-registry.json

# MCP Server
MCP_PORT=3000
MCP_HOST=localhost

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=.leeway/logs

# Features
ENABLE_CACHE=true
CACHE_TTL=3600
ENABLE_INTROSPECTION=true
ENABLE_CHAINING=true

# Performance
MAX_CONCURRENT_EXECUTIONS=5
EXECUTION_TIMEOUT=30000

# Governance
ENABLE_LEEWAY_GOVERNANCE=true
COMPLIANCE_CHECK=true
AUDIT_LOGGING=true
